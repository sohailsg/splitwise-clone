rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to get user ID
    function getUserId() {
      return request.auth.uid;
    }

    // Helper function to check group membership
    function isInGroup(groupId) {
      return isAuthenticated() && getUserId() in get(/databases/$(database)/documents/groups/$(groupId)).data.memberUids;
    }

    // Helper function to check if user is admin
    function isAdmin() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    // Users collection
    match /users/{userId} {
      // Allow read for authenticated users (to find friends by email)
      allow read: if isAuthenticated();

      // Allow write only for the user themselves
      allow create: if isAuthenticated() && getUserId() == userId;
      allow update: if isAuthenticated() && (getUserId() == userId || isAdmin());

      // Friends subcollection
      match /friends/{friendId} {
        // Allow read/write only for the user's own friends
        allow read: if isAuthenticated() && getUserId() == userId;
        allow create: if isAuthenticated() && getUserId() == userId;
        allow delete: if isAuthenticated() && getUserId() == userId;
      }
    }

    // Groups collection
    match /groups/{groupId} {
      // Allow read if user is a member or admin
      allow read: if isAuthenticated() && (getUserId() in resource.data.memberUids || isAdmin());

      // Allow create if authenticated — memberUids must include creator
      allow create: if isAuthenticated() && request.resource.data.memberUids.hasAny([getUserId()]);

      // Allow update if user is a member or admin
      allow update: if isAuthenticated() && (getUserId() in resource.data.memberUids || isAdmin());

      // Allow delete for creator or admin
      allow delete: if isAuthenticated() && (resource.data.createdBy == getUserId() || isAdmin());
    }

    // Expenses collection
    match /expenses/{expenseId} {
      // Allow read if user is in the expense's group or admin
      allow read: if isAuthenticated() && (isInGroup(resource.data.groupId) || isAdmin());

      // Allow create if user is in the group and createdBy matches auth user
      allow create: if isAuthenticated()
        && request.resource.data.createdBy == getUserId()
        && isInGroup(request.resource.data.groupId)
        && request.resource.data.amount > 0;

      // Allow delete for creator or admin
      allow delete: if isAuthenticated() && (resource.data.createdBy == getUserId() || isAdmin());

      // No updates allowed
    }

    // Settlements collection
    match /settlements/{settlementId} {
      // Allow read if user is involved or admin
      allow read: if isAuthenticated()
        && (resource.data.fromUserId == getUserId() || resource.data.toUserId == getUserId() || isAdmin());

      // Allow create if user is one of the participants and amount is valid
      allow create: if isAuthenticated()
        && (request.resource.data.fromUserId == getUserId() || request.resource.data.toUserId == getUserId())
        && request.resource.data.amount > 0;

      // Allow delete for participants or admin
      allow delete: if isAuthenticated()
        && (resource.data.fromUserId == getUserId() || resource.data.toUserId == getUserId() || isAdmin());
    }

    // Recurring expenses collection
    match /recurringExpenses/{recurringId} {
      // Allow read if user is in the group or admin
      allow read: if isAuthenticated() && (isInGroup(resource.data.groupId) || isAdmin());

      // Allow create if user is in the group and createdBy matches auth user
      allow create: if isAuthenticated()
        && request.resource.data.createdBy == getUserId()
        && isInGroup(request.resource.data.groupId);

      // Allow update if user is in the group or admin
      allow update: if isAuthenticated() && (isInGroup(resource.data.groupId) || isAdmin());

      // Allow delete if user is in the group or admin
      allow delete: if isAuthenticated() && (isInGroup(resource.data.groupId) || isAdmin());
    }

    // Feedback collection (new for admin dashboard)
    match /feedback/{feedbackId} {
      // Users can read their own feedback, admins can read all
      allow read: if isAuthenticated()
        && (resource.data.userId == getUserId() || isAdmin());

      // Any authenticated user can create feedback
      allow create: if isAuthenticated()
        && request.resource.data.userId == getUserId();

      // Only admins can update (status, adminReply)
      allow update: if isAdmin();

      // Only admins can delete
      allow delete: if isAdmin();
    }
  }
}
